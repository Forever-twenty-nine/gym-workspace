{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "composite": true,
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": false,
    "rootDir": ".."
  },
  "include": [
    "./**/*.ts",
    "../projects/gym-library/src/lib/enums/**/*.ts",
    "../projects/gym-library/src/lib/models/**/*.ts"
  ],
  "exclude": [
    "./**/*.spec.ts",
    "./**/*.test.ts",
    "./vitest.config.ts"
  ]
}