{
  "name": "gym-workspace",
  "version": "0.0.0",
  "scripts": {
    "emulator:start": "firebase emulators:start --project=default-project --import=./emulator-data",
    "emulator:start:with-export": "firebase emulators:start --project=default-project --import=./emulator-data --export-on-exit=./emulator-data",
    "emulator:export": "firebase emulators:export --project=default-project ./emulator-data",
    "emulator:import": "firebase emulators:start --project=default-project --import=./emulator-data",
    "kill-emulators": "powershell -NoProfile -File scripts/kill-emulator.ps1",
    "gym-admin:serve": "cd projects/gym-admin && npm run start",
    "gym-admin:build": "cd projects/gym-admin && npm run build",
    "gym-admin:test": "cd projects/gym-admin && npm run test",
    "gym-app:serve": "cd projects/gym-app && ionic serve",
    "gym-app:build": "cd projects/gym-app && ionic build",
    "gym-app:android": "cd projects/gym-app && ionic cap run android",
    "gym-app:sync": "cd projects/gym-app && ionic cap sync",
    "library:build": "ng build gym-library",
    "library:watch": "ng build gym-library --watch",
    "dev": "npm run library:build && npm run dev:parallel",
    "dev:parallel": "concurrently \"npm run gym-admin:serve\" \"npm run gym-app:serve\" --names \"admin,app\" --prefix-colors \"cyan,magenta\"",
    "dev:all": "concurrently \"npm run library:watch\" \"npm run gym-admin:serve\" \"npm run gym-app:serve\" --names \"lib,admin,app\" --prefix-colors \"yellow,cyan,magenta\"",
    "dev:with-emulator": "npm run library:build && concurrently \"npm run emulator:start:with-export\" \"npm run gym-admin:serve\" \"npm run gym-app:serve\" --names \"emulator,admin,app\" --prefix-colors \"green,cyan,magenta\"",
    "dev:with-firebase": "npm run library:build && concurrently \"npm run gym-admin:serve:firebase\" \"npm run gym-app:serve:firebase\" --names \"admin,app\" --prefix-colors \"cyan,magenta\"",
    "gym-admin:serve:firebase": "cd projects/gym-admin && npm run start -- --configuration=firebase",
    "gym-app:serve:firebase": "cd projects/gym-app && ionic serve -c firebase",
    "gym-admin:with-emulator": "concurrently \"npm run emulator:start:with-export\" \"npm run gym-admin:serve\" --names \"emulator,admin\" --prefix-colors \"green,cyan\"",
    "gym-app:with-emulator": "concurrently \"npm run emulator:start:with-export\" \"npm run gym-app:serve\" --names \"emulator,app\" --prefix-colors \"green,magenta\"",
    "db:seed": "tsx scripts/seed-data.ts",
    "install:all": "npm install && cd projects/gym-admin && npm install && cd ../gym-app && npm install && cd ../gym-library && npm install"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.8.0",
    "ng-packagr": "^21.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}